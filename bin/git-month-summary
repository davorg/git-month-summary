#!/usr/bin/env -S perl -CS

use v5.40;
use utf8;

use Getopt::Long qw(GetOptions);
use File::Find qw(find);
use File::Spec;
use Cwd qw(abs_path);
use IPC::Open3 qw(open3);
use Symbol qw(gensym);
use OpenAPI::Client::OpenAI;

my $DEFAULT_DIR   = "$ENV{HOME}/git";
my $DEFAULT_MODEL = 'gpt-5.4-mini';

my %opt = (
    dir           => $DEFAULT_DIR,
    model         => $DEFAULT_MODEL,
    max_input_len => 30_000,
);

GetOptions(
    'month=i'         => \$opt{month},
    'year=i'          => \$opt{year},
    'dir=s'           => \$opt{dir},
    'model=s'         => \$opt{model},
    'max-input-len=i' => \$opt{max_input_len},
) or die usage();

die usage() unless defined $opt{month} && defined $opt{year};

validate_inputs(\%opt);

die "OPENAI_API_KEY is not set in the environment\n"
    unless defined $ENV{OPENAI_API_KEY} && length $ENV{OPENAI_API_KEY};

my ($since, $until, $label) = month_range($opt{year}, $opt{month});

my @repos = find_git_repos($opt{dir});

unless (@repos) {
  warn "No repos found\n";
  exit;
}

my $client = OpenAPI::Client::OpenAI->new();

for my $repo (@repos) {
    next unless repo_has_commits($repo);

    my $log = git_month_log($repo, $since, $until);
    next unless defined $log && length $log =~ /\S/;

    my $summary = summarise_repo_changes(
        client        => $client,
        repo          => $repo,
        month_label   => $label,
        model         => $opt{model},
        log           => truncate_text($log, $opt{max_input_len}),
    );

    next unless defined $summary && length $summary;

    say '## ', repo_display_name($repo, $opt{dir});
    say '';
    say $summary;
    say "\n---\n";
}

exit 0;

sub usage {
    return <<"END_USAGE";
Usage:
  git-month-summary --month N --year YYYY [--dir PATH] [--model MODEL]

Examples:
  git-month-summary --month 3 --year 2026
  git-month-summary --month 3 --year 2026 --dir /home/git/personal
  git-month-summary --month 3 --year 2026 --model gpt-5.4

Options:
  --month         Month number (1-12)
  --year          Four-digit year
  --dir           Root directory to search (default: /home/git)
  --model         OpenAI model (default: gpt-5.4-mini)
  --max-input-len Max characters of git log sent to the model (default: 30000)
END_USAGE
}

sub validate_inputs ($opt) {
    die "--month must be between 1 and 12\n"
        unless $opt->{month} >= 1 && $opt->{month} <= 12;

    die "--year must be a sensible four-digit year\n"
        unless $opt->{year} >= 1970 && $opt->{year} <= 2100;

    my $dir = abs_path($opt->{dir})
        // die "Cannot resolve directory '$opt->{dir}'\n";

    die "'$dir' is not a directory\n" unless -d $dir;

    $opt->{dir} = $dir;
}

sub month_range ($year, $month) {
    my $start = sprintf '%04d-%02d-01 00:00:00', $year, $month;

    my ($next_year, $next_month) = $month == 12
        ? ($year + 1, 1)
        : ($year, $month + 1);

    my $end = sprintf '%04d-%02d-01 00:00:00', $next_year, $next_month;

    my @names = qw(
        January February March April May June
        July August September October November December
    );

    my $label = sprintf '%s %04d', $names[$month - 1], $year;

    return ($start, $end, $label);
}

sub find_git_repos ($root) {
    my %seen;
    my @repos;

    find(
        {
            wanted => sub {
                return unless -d $_;

                return unless $_ =~ /\.git$/;

                push @repos, $File::Find::dir;
                $File::Find::prune = 1;

                return;
            },
            no_chdir => 1,
        },
        $root,
    );

    # Also handle the case where the root itself is a repo and File::Find
    # didn't yield it via a child .git directory for some reason.
    if (-d File::Spec->catdir($root, '.git')) {
        my $abs = abs_path($root);
        push @repos, $abs if defined $abs && !$seen{$abs}++;
    }

    return sort @repos;
}

sub git_month_log ($repo, $since, $until) {
    my @cmd = (
        'git',
        '-C', $repo,
        'log',
        '--no-merges',
        "--since=$since",
        "--until=$until",
        '--date=short',
        '--pretty=format:commit %H%nAuthor: %an <%ae>%nDate: %ad%nSubject: %s%n%n%b%n---',
        '--stat=120,80',
    );

    my ($stdout, $stderr, $exit) = run_cmd(@cmd);

    if ($exit != 0) {
        warn "git log failed for $repo: $stderr\n";
        return;
    }

    return $stdout;
}

sub summarise_repo_changes (%args) {
    my $client      = $args{client};
    my $repo        = $args{repo};
    my $month_label = $args{month_label};
    my $model       = $args{model};
    my $log         = $args{log};

    my $prompt = <<"END_PROMPT";
You are summarising a month's Git work for the maintainer of a software project.

Repository:
$repo

Month:
$month_label

Please write a concise summary in British English.

Requirements:
- 2 to 5 bullet points
- focus on what changed, not on commit mechanics
- mention themes such as bug fixes, refactoring, new features, documentation, tests, deployment, build or configuration work
- if the changes are small, say so plainly
- do not invent anything that is not supported by the git log
- do not mention hashes unless they are genuinely useful

Git log follows:

$log
END_PROMPT

    my $tx = eval {
        $client->createChatCompletion(
            {
                body => {
                    model       => $model,
                    temperature => 0.2,
                    messages    => [
                        {
                            role    => 'system',
                            content => 'You produce careful, factual development summaries.',
                        },
                        {
                            role    => 'user',
                            content => $prompt,
                        },
                    ],
                },
            }
        );
    };

    if ($@) {
        warn "OpenAI request failed for $repo: $@\n";
        return;
    }

    my $res = $tx->res;
    unless ($res && $res->is_success) {
        my $body = eval { $res->body } // '(no response body)';
        warn "OpenAI API error for $repo: " . ($res ? $res->code : 'unknown') . " $body\n";
        return;
    }

    my $json = $res->json;
    my $text = $json->{choices}[0]{message}{content};

    unless (defined $text && length $text) {
        warn "OpenAI returned no summary for $repo\n";
        return;
    }

    $text =~ s/\A\s+//;
    $text =~ s/\s+\z//;

    return $text;
}

sub truncate_text ($text, $max_len) {
    return $text if length($text) <= $max_len;

    my $truncated = substr($text, 0, $max_len);
    $truncated .= "\n\n[... git log truncated before sending to the model ...]\n";
    return $truncated;
}

sub repo_display_name ($repo, $root) {
    my $name = $repo;
    $name =~ s/^\Q$root\E\/?//;
    return $name eq '' ? $repo : $name;
}

sub repo_has_commits ($repo) {
    my @cmd = ('git', '-C', $repo, 'rev-parse', '--verify', 'HEAD');
    my (undef, $stderr, $exit) = run_cmd(@cmd);
    return $exit == 0;
}

sub run_cmd (@cmd) {
    my $stderr = gensym;
    my $pid = open3(undef, my $out, $stderr, @cmd);

    local $/ = undef;
    my $stdout = <$out> // '';
    my $errout = <$stderr> // '';

    waitpid $pid, 0;
    my $exit = $? >> 8;

    return ($stdout, $errout, $exit);
}
